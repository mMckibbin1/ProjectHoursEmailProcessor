<FluentDataGrid Items="@Emails" Pagination="@pagination" RowSize="DataGridRowSize.Medium">
    <PropertyColumn Property="@(p => p.BusinessName)" Title="Business Name" Sortable="true" />
    <TemplateColumn Title="Client Name" Sortable="true" SortBy="@clientNameSort">
        @(context.ClientName ?? "N/A")
    </TemplateColumn>
    <PropertyColumn Property="@(p => p.MentorName)" Title="Mentor Name" Sortable="true" />
    <PropertyColumn Property="@(p => p.SessionDate)" Title="Session Date" Format="yyyy-MM-dd" Sortable="true" IsDefaultSortColumn="true" InitialSortDirection="DataGridSortDirection.Descending" />
    <TemplateColumn Title="Completed Hours" Sortable="true" SortBy="@completedHoursSort">
        @(context.CompletedHours?.ToString() ?? "N/A")
    </TemplateColumn>
    <TemplateColumn Title="Email Type" Sortable="true" SortBy="emailTypeSort">
        @if(context.EmailType == EmailType.Approval)
        {
            <FluentIcon Value="new Icons.Filled.Size20.QuestionCircle()" Color="Color.Info" Title="Sent for Approval" />
        }
        else if (context.EmailType == EmailType.Approved)
        {
            <FluentIcon Value="new Icons.Filled.Size20.CheckmarkCircle()" Color="Color.Success" Title="Hours Approved" />
        }
        else
        {
            <FluentIcon Value="new Icons.Filled.Size20.DismissCircle()" Color="Color.Error" Title="Hours Rejected" />
        }
    </TemplateColumn>
</FluentDataGrid>

<FluentPaginator State="@pagination" />

@code {
    [Parameter, EditorRequired]
    public IQueryable<EmailGridItem> Emails { get; set; }

    private readonly PaginationState pagination = new PaginationState() { ItemsPerPage = 30 };

    private readonly GridSort<EmailGridItem> clientNameSort = GridSort<EmailGridItem>.ByAscending(x => x.ClientName);
    private readonly GridSort<EmailGridItem> completedHoursSort = GridSort<EmailGridItem>.ByAscending(x => x.CompletedHours);
    private readonly GridSort<EmailGridItem> emailTypeSort = GridSort<EmailGridItem>.ByAscending(x => x.EmailType);
}
